{
	"name": "kanbani",
	"version": "0.0.1",
	"description": "AI-powered kanban board for Claude Code. Manage tasks, run agents, review diffs — all from a warm, cozy UI.",
	"bin": {
		"kanbani": "./bin/kanbani.js"
	},
	"files": [
		"bin/",
		"src/",
		"public/",
		"data/.gitkeep",
		"package.json",
		"tsconfig.json",
		"next.config.ts",
		"postcss.config.mjs",
		"biome.json"
	],
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/dm1tryG/Kanbani.git"
	},
	"keywords": [
		"kanban",
		"claude",
		"claude-code",
		"ai",
		"agent",
		"task-management",
		"developer-tools"
	],
	"author": "dm1tryG",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/dm1tryG/Kanbani/issues"
	},
	"homepage": "https://github.com/dm1tryG/Kanbani#readme",
	"dependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"next": "^16.2.1",
		"react": "^19.2.4",
		"react-diff-view": "^3.3.2",
		"react-dom": "^19.2.4",
		"react-markdown": "^10.1.0",
		"unidiff": "^1.0.4",
		"uuid": "^13.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@playwright/test": "^1.58.2",
		"@tailwindcss/postcss": "^4.2.2",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/uuid": "^10.0.0",
		"@vitejs/plugin-react": "^6.0.1",
		"jsdom": "^29.0.1",
		"playwright": "^1.58.2",
		"postcss": "^8.5.8",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	}
}
